<?xml version="1.0" encoding="UTF-8"?>

<?import java.net.URL?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Hyperlink?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="600.0" prefWidth="800.0" styleClass="gradient-bg" xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.newsreader.controller.LoginController">
    <stylesheets>
        <URL value="@../css/styles.css" />
    </stylesheets>
    
    <VBox alignment="CENTER" spacing="20.0" AnchorPane.bottomAnchor="0.0" AnchorPane.leftAnchor="0.0" AnchorPane.rightAnchor="0.0" AnchorPane.topAnchor="0.0">
        <VBox alignment="CENTER" spacing="5.0">
            <Label styleClass="title-label" text="AI NEWS &amp; NOTICE READER" />
            <Label styleClass="subtitle-label" text="Module 1: User Management Portal" />
        </VBox>
        
        <VBox maxHeight="-Infinity" maxWidth="-Infinity" prefWidth="420.0" spacing="20.0" styleClass="card">
            <Label styleClass="section-label" text="Sign In" />
            
            <VBox spacing="8.0">
                <Label styleClass="form-label" text="Email Address" />
                <TextField fx:id="emailField" promptText="Enter your email" />
            </VBox>
            
            <VBox spacing="8.0">
                <Label styleClass="form-label" text="Password" />
                <PasswordField fx:id="passwordField" promptText="Enter your password" />
            </VBox>
            
            <Button maxWidth="1.7976931348623157E308" onAction="#handleLogin" styleClass="button-primary" text="Sign In" />
            
            <VBox alignment="CENTER" style="-fx-padding: 10px 0 0 0;">
                <Hyperlink onAction="#handleNavigateToRegister" styleClass="hyperlink-custom" text="Don't have an account? Register here" />
            </VBox>
        </VBox>
    </VBox>
</AnchorPane>
